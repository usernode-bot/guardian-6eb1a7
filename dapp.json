{
  "name": "Guardian",
  "secrets": [],
  "tests": [
    {
      "name": "App shell loads",
      "path": "/",
      "expectSelector": "nav"
    },
    {
      "name": "Home screen displays Guardian Hero",
      "path": "/",
      "expectText": "Guardian #001"
    },
    {
      "name": "Guardian status badge shows ONLINE",
      "path": "/",
      "expectText": "ONLINE"
    },
    {
      "name": "Node API returns mock data",
      "path": "/api/node",
      "expectText": "online"
    },
    {
      "name": "FG Progress shows NOT ELIGIBLE when below 60 minutes",
      "path": "/",
      "expectText": "NOT ELIGIBLE"
    },
    {
      "name": "Mint button appears when eligible (60+ minutes)",
      "path": "/?demo=eligible",
      "expectText": "Mint Guardian"
    },
    {
      "name": "Mint button is clickable and transitions to minted state",
      "path": "/?demo=eligible",
      "expectText": "READY TO MINT"
    },
    {
      "name": "Guardian Gallery loads with all 500 guardians",
      "path": "/guardians.html",
      "expectText": "Guardian Gallery"
    },
    {
      "name": "Guardian Gallery displays guardian cards",
      "path": "/guardians.html",
      "expectSelector": ".tier-filter"
    },
    {
      "name": "Guardian Gallery shows allocation stats",
      "path": "/guardians.html",
      "expectText": "Available"
    }
  ]
}