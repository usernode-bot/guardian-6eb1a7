{
  "name": "Guardian",
  "secrets": [
    {
      "key": "TESTNET_RPC_URL",
      "description": "JSON-RPC endpoint for testnet balance queries (e.g., Sepolia, Goerli public RPC)",
      "required": false,
      "private": false,
      "staging_default": "https://sepolia.drpc.org"
    }
  ],
  "tests": [
    {
      "name": "App shell loads",
      "path": "/",
      "expectSelector": "nav"
    },
    {
      "name": "Node API returns mock data",
      "path": "/api/node",
      "expectText": "status"
    },
    {
      "name": "Guardian Gallery loads with all 500 guardians",
      "path": "/guardians.html",
      "expectText": "Guardian Gallery"
    },
    {
      "name": "Guardian Gallery displays guardian cards",
      "path": "/guardians.html",
      "expectSelector": ".tier-filter"
    },
    {
      "name": "Guardian Gallery shows allocation stats",
      "path": "/guardians.html",
      "expectText": "Available"
    },
    {
      "name": "Supply stats API returns guardian counts",
      "path": "/api/supply/stats",
      "expectText": "total"
    },
    {
      "name": "Guardian history API returns audit log",
      "path": "/api/guardian/history",
      "expectText": "events"
    },
    {
      "name": "Wallet API returns address and balance fields",
      "path": "/api/wallet",
      "expectText": "address"
    },
    {
      "name": "Evolution page loads with Share Guardian button",
      "path": "/evolution.html",
      "expectText": "Share Guardian"
    },
    {
      "name": "Transfer cleanup API works",
      "path": "/api/guardian/transfer/cleanup",
      "expectText": "success"
    }
  ]
}