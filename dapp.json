{
  "name": "Guardian",
  "secrets": [],
  "tests": [
    {
      "name": "App shell loads",
      "path": "/",
      "expectSelector": "nav"
    },
    {
      "name": "Home screen displays Guardian Hero",
      "path": "/",
      "expectText": "Guardian #001"
    },
    {
      "name": "Node API returns mock data",
      "path": "/api/node",
      "expectText": "status"
    },
    {
      "name": "GuardianHero displays stage badge",
      "path": "/",
      "expectText": "Stage: GUARDIAN"
    },
    {
      "name": "GuardianHero avatar shows 🦾 for GUARDIAN stage (10-49 hours)",
      "path": "/",
      "expectText": "🦾"
    },
    {
      "name": "Guardian Gallery loads with all 500 guardians",
      "path": "/guardians.html",
      "expectText": "Guardian Gallery"
    },
    {
      "name": "Guardian Gallery displays guardian cards",
      "path": "/guardians.html",
      "expectSelector": ".tier-filter"
    },
    {
      "name": "Guardian Gallery shows allocation stats",
      "path": "/guardians.html",
      "expectText": "Available"
    },
    {
      "name": "Supply stats API returns guardian counts",
      "path": "/api/supply/stats",
      "expectText": "total"
    },
    {
      "name": "Guardian history API returns audit log",
      "path": "/api/guardian/history",
      "expectText": "events"
    },
    {
      "name": "Signaling endpoints accept WebRTC offers",
      "path": "/api/signaling/offer",
      "expectText": "error"
    },
    {
      "name": "Auth confirmation modal shows on app load with token",
      "path": "/",
      "expectText": "Confirm Sign In"
    }
  ]
}